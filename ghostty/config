# テーマ
theme = Dracula

# フォント
font-family = "JetBrainsMono Nerd Font"
font-size = 15
font-thicken = true


# 背景透過
background-opacity = 0.70
background-blur-radius = 20

# 非アクティブペインを暗く
unfocused-split-opacity = 0.7

# ウィンドウ
window-padding-x = 15 
window-padding-y = 5
window-padding-balance = true
window-height = 40
window-width = 180


# カーソル
cursor-color = FF88FF
cursor-style-blink = true


# マウススクロール
# precision: トラックパッド用（デフォルト0.1は遅すぎる場合あり）
# discrete: マウスホイール用（デフォルト1）
mouse-scroll-multiplier = precision:1,discrete:3


# Mac特有
macos-titlebar-style = native
macos-titlebar-proxy-icon= hidden
macos-window-shadow = true
macos-icon = custom-style
macos-icon-ghost-color = 010101
macos-icon-screen-color = FF88FF
macos-icon-frame = plastic


# quickターミナル
quick-terminal-position = "center"
quick-terminal-screen = "main"
quick-terminal-animation-duration = 0.3
keybind = "global:cmd+shift+t=toggle_quick_terminal"

